rules_version = '2';

// Product images, datasheets, drawings — public read, admin write.
service firebase.storage {
  match /b/{bucket}/o {
    match /products/{partNumber}/{file=**} {
      allow read: if true;
      allow write: if request.auth != null
        && firestore.exists(/databases/(default)/documents/admins/$(request.auth.uid));
    }
  }
}
