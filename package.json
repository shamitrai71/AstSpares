{
  "name": "astspares",
  "version": "0.1.0",
  "private": true,
  "description": "ASTSPARES — B2B industrial procurement platform for storage-tank spare parts (catalog + RFQ).",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "export:products": "tsx scripts/export-products.ts",
    "seed": "tsx scripts/seed.ts",
    "predeploy": "npm run export:products && npm run build",
    "deploy": "firebase deploy --only hosting,firestore,functions"
  },
  "dependencies": {
    "firebase": "^10.12.2",
    "geist": "^1.7.2",
    "next": "^14.2.35",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.14.9",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.19",
    "firebase-admin": "^12.2.0",
    "postcss": "^8.4.39",
    "tailwindcss": "^3.4.4",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3"
  }
}
